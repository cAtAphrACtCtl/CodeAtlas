{
  "name": "codeatlas-vscode-extension",
  "displayName": "CodeAtlas",
  "description": "VS Code command surface for local CodeAtlas repository discovery and management.",
  "version": "0.1.0",
  "private": true,
  "publisher": "codeatlas",
  "files": [
    "dist/**",
    "package.json",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "npm run typecheck && node ./esbuild.mjs",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "watch": "npm-run-all -p watch:types watch:bundle",
    "watch:types": "tsc --noEmit --watch -p ./tsconfig.json",
    "watch:bundle": "node ./esbuild.mjs --watch",
    "package": "npm run typecheck && node ./esbuild.mjs --production",
    "package:vsix": "npm run package && vsce package -o codeatlas-vscode-extension.vsix --no-dependencies --allow-missing-repository --skip-license"
  },
  "contributes": {
    "commands": [
      {
        "command": "codeatlas.registerCurrentWorkspace",
        "title": "CodeAtlas: Register Current Workspace"
      },
      {
        "command": "codeatlas.discoverRepositories",
        "title": "CodeAtlas: Discover Repositories"
      },
      {
        "command": "codeatlas.showRepositoryStatus",
        "title": "CodeAtlas: Show Repository Status"
      },
      {
        "command": "codeatlas.openConfig",
        "title": "CodeAtlas: Open CodeAtlas Config"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}