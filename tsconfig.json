{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/core/**/*.ts", "src/mcp-server/**/*.ts", "src/cli/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/vscode-extension"]
}