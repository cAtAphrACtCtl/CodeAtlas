{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/cli/main.ts",
      "args": ["list"],
      "env": {
        "CODEATLAS_CONFIG": "${workspaceFolder}/config/codeatlas.json"
      },
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug CodeAtlas MCP",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "restart": true,
      "timeout": 30000,
      "preLaunchTask": "codeatlas: debug mcp",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Run CodeAtlas Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-extension/dist/**/*.cjs"
      ],
      "preLaunchTask": "codeatlas: watch extension"
    },
    {
      "name": "Attach CodeAtlas MCP Watch",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "restart": true,
      "timeout": 30000,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "preLaunchTask": "codeatlas: watch mcp"
    }
  ],
  "compounds": [
    {
      "name": "CodeAtlas Dev: Extension + MCP",
      "configurations": [
        "Run CodeAtlas Extension",
        "Debug CodeAtlas MCP"
      ],
      "stopAll": true
    },
    {
      "name": "CodeAtlas Dev: Full Stack Watch",
      "configurations": [
        "Run CodeAtlas Extension",
        "Attach CodeAtlas MCP Watch"
      ],
      "stopAll": true
    }
  ]
}