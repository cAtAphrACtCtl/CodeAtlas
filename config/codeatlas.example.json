{
  "registryPath": "./data/registry/repositories.local.json",
  "metadataPath": "./data/metadata/index-status.local.json",
  "indexRoot": "./data/indexes",
  "lexicalBackend": {
    "kind": "zoekt",
    "zoektIndexExecutable": "zoekt-index",
    "zoektSearchExecutable": "zoekt",
    "allowBootstrapFallback": true,
    "bootstrapFallback": {
      "kind": "ripgrep",
      "executable": "rg",
      "fallbackToNaiveScan": true
    }
  },
  "search": {
    "defaultLimit": 20,
    "maxLimit": 100,
    "maxBytesPerFile": 262144
  },
  "indexing": {
    "indexBuildTimeoutMs": 1800000,
    "symbolConcurrency": 0
  },
  "mcp": {
    "serverName": "codeatlas",
    "serverVersion": "0.1.0"
  },
  "logging": {
    "enabled": true,
    "level": "info",
    "format": "jsonl",
    "file": {
      "enabled": true,
      "path": "./data/debug/codeatlas.log.jsonl"
    },
    "includeErrorStreamTails": false
  },
  "debug": {
    "scopes": [],
    "trace": false
  }
}