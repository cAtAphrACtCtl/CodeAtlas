{
  "registryPath": "../data/registry/repositories.local.json",
  "metadataPath": "../data/metadata/index-status.local.json",
  "indexRoot": "../data/indexes",
  "lexicalBackend": {
    "kind": "zoekt",
    "zoektIndexExecutable": "../.tools/zoekt/bin/zoekt-index.exe",
    "zoektSearchExecutable": "../.tools/zoekt/bin/zoekt.exe",
    "allowBootstrapFallback": true,
    "bootstrapFallback": {
      "kind": "ripgrep",
      "executable": "rg",
      "fallbackToNaiveScan": true
    }
  },
  "search": {
    "defaultLimit": 20,
    "maxLimit": 100,
    "maxBytesPerFile": 262144
  },
  "mcp": {
    "serverName": "codeatlas",
    "serverVersion": "0.1.0"
  },
  "logging": {
    "enabled": true,
    "level": "debug",
    "format": "jsonl",
    "file": {
      "enabled": true,
      "path": "../data/debug/codeatlas.log.jsonl"
    },
    "includeErrorStreamTails": true
  },
  "debug": {
    "scopes": ["runtime", "mcp", "zoekt", "indexer"],
    "trace": true
  }
}
